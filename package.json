{
  "name": "@sublang/cligent",
  "version": "0.1.0",
  "description": "Unified interface for CLI-based AI coding agents",
  "type": "module",
  "license": "Apache-2.0",
  "workspaces": [
    "apps/*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sublang-dev/cligent.git"
  },
  "homepage": "https://github.com/sublang-dev/cligent#readme",
  "bugs": "https://github.com/sublang-dev/cligent/issues",
  "keywords": [
    "ai",
    "agent",
    "cli",
    "claude",
    "codex",
    "gemini",
    "opencode",
    "unified",
    "adapter"
  ],
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./adapters/claude-code": {
      "import": "./dist/adapters/claude-code.js",
      "types": "./dist/adapters/claude-code.d.ts"
    },
    "./adapters/codex": {
      "import": "./dist/adapters/codex.js",
      "types": "./dist/adapters/codex.d.ts"
    },
    "./adapters/gemini": {
      "import": "./dist/adapters/gemini.js",
      "types": "./dist/adapters/gemini.d.ts"
    },
    "./adapters/opencode": {
      "import": "./dist/adapters/opencode.js",
      "types": "./dist/adapters/opencode.d.ts"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "build:all": "tsc && npm run build --workspaces --if-present",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:acceptance": "npm run test:acceptance -w apps/allsides --",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@anthropic-ai/claude-agent-sdk": "*",
    "@openai/codex-sdk": "*",
    "@opencode-ai/sdk": "*"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/claude-agent-sdk": {
      "optional": true
    },
    "@openai/codex-sdk": {
      "optional": true
    },
    "@opencode-ai/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.69",
    "@openai/codex-sdk": "^0.107.0",
    "@opencode-ai/sdk": "^1.2.17",
    "@types/node": "^25.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
