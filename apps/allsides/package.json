{
  "name": "@sublang/allsides",
  "version": "0.1.0",
  "description": "Multi-agent tmux chat app powered by cligent",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sublang-dev/cligent.git",
    "directory": "apps/allsides"
  },
  "homepage": "https://github.com/sublang-dev/cligent/tree/main/apps/allsides#readme",
  "bugs": "https://github.com/sublang-dev/cligent/issues",
  "keywords": [
    "ai",
    "agent",
